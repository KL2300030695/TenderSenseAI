rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TENDER SENSE AI - SECURITY RULES
     * 
     * Updated to allow creation by any signed-in user for prototype testing.
     * Administrative actions (update/delete) remain restricted.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.bidderId == request.auth.uid;
    }

    function isNewDocOwner() {
      return isSignedIn() && request.resource.data.bidderId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /bidders/{bidderId} {
      allow get: if isOwner(bidderId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(bidderId);
      allow update: if isOwner(bidderId);
      allow delete: if isAdmin();
    }

    match /tenders/{tenderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); // Allow creation for prototyping
      allow update, delete: if isAdmin();

      match /documents/{documentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }

      match /criteria/{criterionId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /bidderSubmissionDocuments/{submissionDocumentId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isSignedIn();
      allow create: if isNewDocOwner();
      allow update: if isDocOwner();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /bidderExtractedDataPoints/{dataPointId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    match /tenderEvaluationSummaries/{evaluationSummaryId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); // Allow creation for prototyping
      allow update, delete: if isAdmin();

      match /criterionResults/{criterionResultId} {
        allow get: if isDocOwner() || isAdmin();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /reviewActivities/{activityId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin(); 
      allow update, delete: if false;
    }
  }
}