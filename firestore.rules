rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TENDER SENSE AI - SECURITY RULES DOCUMENTATION
     *
     * Core Philosophy:
     * This ruleset implements a hybrid security model combining Role-Based Access Control (RBAC) 
     * and Owner-Based Access Control (OBAC). It prioritizes "Authorization Independence" by
     * relying on denormalized IDs (bidderId, tenderId) within documents to avoid deep lookups.
     *
     * Data Structure:
     * - /users & /bidders: Private user and company profiles.
     * - /roles_admin: A specialized collection used to verify administrative privileges via existence checks.
     * - /tenders: Publicly accessible (for authenticated users) data regarding government opportunities.
     * - /bidderSubmissionDocuments & /bidderExtractedDataPoints: Private bidder data, accessible by the owner and admins.
     * - /tenderEvaluationSummaries: AI-generated evaluations, readable by bidders and manageable by admins.
     * - /reviewActivities: Immutable audit logs for administrative actions.
     *
     * Key Security Decisions:
     * 1. Admin Verification: Admin status is determined by the presence of a document in /roles_admin/{userId}.
     * 2. Denormalization: Fields like 'bidderId' are strictly required and validated on creation to ensure 
     *    future authorization checks (like 'isOwner') remain performant and reliable.
     * 3. Immutability: Audit logs (ReviewActivity) are "create-only" to ensure the integrity of the audit trail.
     * 4. Prototyping Flexibility: While access is strictly controlled, the specific content and data types 
     *    of fields are not enforced to allow for rapid schema iteration.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the existing document belongs to the authenticated user. */
    function isDocOwner() {
      return isSignedIn() && resource.data.bidderId == request.auth.uid;
    }

    /** Checks if the incoming document will belong to the authenticated user. */
    function isNewDocOwner() {
      return isSignedIn() && request.resource.data.bidderId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Access rules for basic user profiles.
     * @path /users/{userId}
     * @allow Authenticated user (get, list, create, update) if they are the owner.
     * @deny Any user attempting to access or modify another user's profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource != null;
      allow delete: if false; // Profiles are typically not deleted in this app flow.
    }

    /**
     * @description Existence-based admin role registry.
     * @path /roles_admin/{userId}
     * @allow All signed-in users (get) to verify roles; only admins (create, update, delete).
     * @deny Non-admins attempting to elevate privileges.
     * @principle Database-Based Access Control (DBAC).
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Company profiles for bidders.
     * @path /bidders/{bidderId}
     * @allow Owner (get, create, update) or Admin (get, list).
     * @deny Bidders viewing other bidders' profiles.
     * @principle Enforces document ownership for writes and profile privacy.
     */
    match /bidders/{bidderId} {
      allow get: if isOwner(bidderId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(bidderId) && request.resource.data.id == bidderId;
      allow update: if isOwner(bidderId) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Government tender documents and metadata.
     * @path /tenders/{tenderId}
     * @allow Any authenticated user (get, list); only Admins (create, update, delete).
     * @deny Non-admins attempting to modify tender details.
     * @principle Public read with owner-only writes (where Admin acts as the system owner).
     */
    match /tenders/{tenderId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /**
       * @description Files and documents associated with a tender.
       * @path /tenders/{tenderId}/documents/{documentId}
       */
      match /documents/{documentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      /**
       * @description Extracted eligibility criteria for a tender.
       * @path /tenders/{tenderId}/criteria/{criterionId}
       */
      match /criteria/{criterionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Documents submitted by bidders for specific tenders.
     * @path /bidderSubmissionDocuments/{submissionDocumentId}
     * @allow Owner (get, list, create, delete) or Admin (get, list).
     * @deny Access to submission documents belonging to other companies.
     * @principle Authorization Independence via denormalized bidderId.
     */
    match /bidderSubmissionDocuments/{submissionDocumentId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isSignedIn(); // Filtered by bidderId in query
      allow create: if isNewDocOwner();
      allow update: if isDocOwner() && resource != null && request.resource.data.bidderId == resource.data.bidderId;
      allow delete: if (isDocOwner() || isAdmin()) && resource != null;
    }

    /**
     * @description Structured data extracted from bidder documents.
     * @path /bidderExtractedDataPoints/{dataPointId}
     * @allow Owner (get, list) or Admin (get, list, create, update).
     * @deny Unauthorized access to extracted sensitive company data.
     * @principle Restricts access to a user's own data tree and extracted results.
     */
    match /bidderExtractedDataPoints/{dataPointId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isSignedIn(); // Filtered by bidderId in query
      allow create: if isAdmin() || isNewDocOwner();
      allow update: if (isDocOwner() || isAdmin()) && resource != null && request.resource.data.bidderId == resource.data.bidderId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Overall evaluation results for a bidder's tender submission.
     * @path /tenderEvaluationSummaries/{evaluationSummaryId}
     * @allow Owner (get, list) or Admin (all permissions).
     * @deny Bidders attempting to modify their own evaluation results.
     * @principle Separation of concerns: users read outcomes, admins manage the process.
     */
    match /tenderEvaluationSummaries/{evaluationSummaryId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isSignedIn(); // Filtered by bidderId in query
      allow create, update, delete: if isAdmin();

      /**
       * @description Evaluation of individual criteria within a summary.
       * @path /tenderEvaluationSummaries/{evaluationSummaryId}/criterionResults/{criterionResultId}
       */
      match /criterionResults/{criterionResultId} {
        allow get: if isDocOwner() || isAdmin();
        allow list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Immutable audit logs of human review actions.
     * @path /reviewActivities/{activityId}
     * @allow Admins (get, list, create).
     * @deny Modification or deletion of audit logs (Immutability).
     * @principle Auditable and maintainable logic for sensitive state changes.
     */
    match /reviewActivities/{activityId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin(); 
      allow update, delete: if false; // Audit logs must be immutable.
    }
  }
}